{
  "name": "dentalchain-backend",
  "version": "1.0.0",
  "description": "DentalChain \u2014 Dental Implant Traceability Backend",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --forceExit --runInBand",
    "test:unit": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --forceExit --testPathPatterns=tests/unit",
    "test:integration": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --forceExit --testPathPatterns=tests/integration --runInBand",
    "test:regression": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --forceExit --testPathPatterns=tests/regression --runInBand",
    "test:watch": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --forceExit --runInBand --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@hyperledger/fabric-gateway": "^1.10.1",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}